# Export these vars in your shell, or use direnv (add `dotenv .env` to .envrc).
# podmind does NOT auto-load .env — you must export the vars yourself.
# .env is gitignored; never commit real credentials.

# === REQUIRED ===

# Path to the data vault containing raw/ and wiki/ subdirectories.
# E.g. /home/you/podcast-wiki or /home/you/Documents/podmind-vault
PODMIND_DATA_ROOT=/home/you/podcast-wiki

# === OPTIONAL ===

# Custom secrets file location. Default: ~/.config/podmind/secrets.json
# PODMIND_SECRETS=/path/to/secrets.json

# === LLM PROVIDER (chat) ===
# First-hit-wins: env var → secrets.json → built-in defaults (DeepSeek V4).
# Set all three together to use a different provider.
# PODMIND_LLM_PROVIDER=openai-compat   # "openai-compat" | "anthropic"
# PODMIND_LLM_BASE_URL=https://api.deepseek.com/v1
# PODMIND_LLM_MODEL=deepseek-chat
# PODMIND_LLM_API_KEY=sk-...           # or set llm_api_key in secrets.json

# === LLM PROVIDER (embeddings) ===
# Defaults: OpenRouter text-embedding-3-small. Always openai-compat wire protocol.
# PODMIND_EMBED_BASE_URL=https://openrouter.ai/api/v1
# PODMIND_EMBED_MODEL=openai/text-embedding-3-small
# PODMIND_EMBED_API_KEY=sk-or-...      # or set embed_api_key in secrets.json
#                                      # legacy OPENROUTER_API_KEY is also honored

# === EMAIL / DAILY DIGEST ===
# All three must be set together for email delivery to work (daily_digest.py).
# RESEND_API_KEY=re_...
# EMAIL_FROM=podcast-wiki@yourdomain.com
# PODCAST_DIGEST_TO=you@yourdomain.com

# === WHISPER LOOP TUNING (used by cron/whisper.sh) ===
# WHISPER_BATCH=50                # episodes per Python invocation; Python aborts mid-batch on AC drop
# WHISPER_BATTERY_SLEEP=300       # seconds to sleep when on battery
# WHISPER_IDLE_SLEEP=1800         # seconds to sleep when backlog empty
# WHISPER_USER_ACTIVE_SLEEP=120   # seconds to sleep when user is active (idle < threshold)
# WHISPER_USER_IDLE_SEC=300       # require ≥N seconds of no user input before starting a batch

# === SECRETS (go in ~/.config/podmind/secrets.json, NOT here) ===
# {
#   "llm_api_key": "sk-...",           # required for bin/ingest_run.py / bin/summarize.py
#   "deepseek_api_key": "sk-...",      # legacy alias for llm_api_key; still honored
#   "embed_api_key": "sk-or-...",      # for bin/embed_all.py / bin/embed_topics.py
#   "pocketcasts_token": "...",        # written by: uv run python -m podmind.pocketcasts login
#                                      # (pocketcasts_email is also written; no user/pass keys needed)
#   "podcast_index_key": "...",        # optional; podcast-index transcript tier
#   "podcast_index_secret": "..."
# }
